# LLM local por defecto
HADES_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4
OLLAMA_THINK=false
OLLAMA_NUM_CTX=4096
OLLAMA_CONVERSATION_TEMPERATURE=0.4
OLLAMA_EXTRACTION_TEMPERATURE=0.1
OLLAMA_CONVERSATION_NUM_PREDICT=300
OLLAMA_JSON_NUM_PREDICT=700

# Audio / micrófono y salida
HADES_AUDIO_INPUT_DEVICE_ID=11
# Dejalo vacío para usar salida default de Windows. Si no se escucha, poné el ID de tus audífonos.
HADES_AUDIO_OUTPUT_DEVICE_ID=
HADES_SAMPLE_RATE=16000

# Grabación de comandos: corta sola tras silencio, no por tiempo fijo.
HADES_COMMAND_START_TIMEOUT_SECONDS=10.0
HADES_COMMAND_SILENCE_TIMEOUT_SECONDS=2.8
HADES_COMMAND_MAX_RECORD_SECONDS=20.0
HADES_COMMAND_MIN_RECORD_SECONDS=0.8
HADES_VOICE_ENERGY_THRESHOLD=0.004
HADES_COMMAND_PREROLL_SECONDS=0.35
HADES_STT_DEBUG_ENERGY=false

# Sonidos cortos de estado
HADES_ENABLE_AUDIO_CUES=true
HADES_CUE_VOLUME=0.16
HADES_CUE_SAMPLE_RATE=16000

# Wake word preentrenada actual. También se puede activar por espacio o chat escrito.
HADES_ENABLE_WAKE_WORD=true
HADES_WAKE_WORD=hey jarvis
HADES_WAKE_THRESHOLD=0.85
HADES_WAKE_COOLDOWN_SECONDS=1.5

# Whisper
HADES_WHISPER_MODEL=base
HADES_WHISPER_LANGUAGE=Spanish

# Kokoro TTS
HADES_ENABLE_TTS=true
HADES_AUTOPLAY_TTS=true
KOKORO_MODEL_PATH=models/kokoro/kokoro-v1.0.onnx
KOKORO_VOICES_PATH=models/kokoro/voices-v1.0.bin
KOKORO_VOICE=em_alex
KOKORO_SPEED=1.15
KOKORO_LANG=es

# Gemini opcional como fallback
# HADES_LLM_PROVIDER=gemini
# GEMINI_API_KEY=tu_api_key
# HADES_TEXT_MODEL=gemini-2.5-flash
