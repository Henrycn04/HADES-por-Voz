# cambiar el nombre a .env (así se lo come el .gitignore) y poner el API key dentro de dicho archivo
GEMINI_API_KEY= API_KEY :D
HADES_TEXT_MODEL=gemini-2.5-flash
HADES_TTS_MODEL=gemini-3.1-flash-tts-preview
HADES_TTS_VOICE=Kore
# cambiar a false para quitar el habla
HADES_ENABLE_TTS=true
HADES_AUTOPLAY_TTS=true
